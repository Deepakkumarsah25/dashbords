<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>History - RIDTECH</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/Allindiatestserice/History.css">
   
</head>

<body>

    <%- include("../common/allindiatestheader.ejs") %>

        <div id="historyPageContent" style="display: none;">
            <div class="history-container">


                <% function getGroup(date){ const d=new Date(date); const today=new Date(); today.setHours(0,0,0,0);
                    const yesterday=new Date(today); yesterday.setDate(today.getDate() - 1); const weekAgo=new
                    Date(today); weekAgo.setDate(today.getDate() - 7); d.setHours(0,0,0,0);
                    if(d.getTime()===today.getTime()) return "Today" ; if(d.getTime()===yesterday.getTime())
                    return "Yesterday" ; if(d> weekAgo) return "This week";
                    return "Older";
                    }

                    let grouped = {};

                    if(history && history.length){
                    history.forEach(item => {
                    const group = getGroup(item.viewedAt);
                    if(!grouped[group]) grouped[group] = [];
                    grouped[group].push(item);
                    });
                    }

                    const order = ["Today","Yesterday","This week","Older"];
                    %>

                    <div class="history-container">

                        <div class="history-header">
                            <h2><i class="fas fa-history"></i> History</h2>
                            <div>
                                <button id="clearAllHistoryBtn">Clear all history</button>
                                <button id="pauseHistoryBtn">Pause history</button>
                            </div>
                        </div>

                        <% if(history && history.length> 0){ %>

                            <% order.forEach(group=> {
                                if(grouped[group]){ %>

                                <h3 style="margin:20px 0 10px;">
                                    <%= group %>
                                </h3>

                                <% grouped[group].forEach(item=> {

                                    if(!item.test) return; // 🔥 IMPORTANT FIX

                                    %>

                                    <div class="history-item">

                                        <div class="history-left"
                                            onclick="window.location.href='/National-Test-Series/test/<%= item.test._id %>'">


                                            <div class="history-thumb">

                                                <img src="<%= item.test.thumbnail && item.test.thumbnail !== '' ? item.test.thumbnail : 'https://picsum.photos/300/200' %>"
                                                    alt="thumbnail" onerror="this.src='https://picsum.photos/300/200'">

                                            </div>

                                            <div class="history-info">
                                                <div class="history-title">
                                                    <%= item.test.name %>
                                                </div>
                                                <div class="history-meta">
                                                    <%= item.test.teacher?.name || "RIDTECH" %>
                                                </div>
                                            </div>

                                        </div>

                                        <!-- 🔥 RIGHT SIDE THREE DOTS -->
                                        <div class="history-actions">
                                            <span class="three-dots">⋮</span>

                                            <div class="action-menu">
                                                <div class="delete-item" data-id="<%= item._id %>">
                                                    🗑️ Delete
                                                </div>
                                            </div>
                                        </div>

                                    </div>

                                    <% }) %>

                                        <% } }) %>

                                            <% } else { %>

                                                <p style="text-align:center;padding:40px;">No history found</p>

                                                <% } %>
                    </div>
            </div>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {

                const dynamicContent = document.getElementById("dynamicContent");
                const tempContent = document.getElementById("historyPageContent");

                if (dynamicContent && tempContent) {
                    const container = tempContent.querySelector(".history-container");
                    if (container) {
                        dynamicContent.innerHTML = "";
                        dynamicContent.appendChild(container);
                    }
                    tempContent.remove();
                }

                // ================= CLEAR ALL HISTORY =================
                const clearBtn = document.getElementById("clearAllHistoryBtn");

                if (clearBtn) {
                    clearBtn.addEventListener("click", async () => {

                        if (!confirm("Delete all history?")) return;

                        try {
                            const res = await fetch("/National-Test-Series/history/clear", {
                                method: "POST",
                                headers: {
                                    "Content-Type": "application/json"
                                }
                            })
                            const data = await res.json();

                            if (res.status === 401) {
                                alert("Please login first 🔐");
                                window.location.href = "/login";
                                return;
                            }

                            if (!res.ok || !data.success) {
                                alert(data.msg || "Failed to clear history ❌");
                                return;
                            }

                            location.reload();

                        } catch (err) {
                            console.error(err);
                            alert("Server error ❌");
                        }
                    });
                }

                // ================= PAUSE BUTTON =================
                const pauseBtn = document.getElementById("pauseHistoryBtn");

                if (pauseBtn) {
                    pauseBtn.addEventListener("click", () => {
                        alert("History pause coming soon");
                    });
                }

                // ================= MENU HANDLING =================
                function closeAllMenus() {
                    document.querySelectorAll('.action-menu').forEach(menu => {
                        menu.classList.remove('show');
                    });
                }

                // ================= PER ITEM DELETE =================
                document.querySelectorAll('.history-actions').forEach(actionsDiv => {

                    const dots = actionsDiv.querySelector('.three-dots');
                    const menu = actionsDiv.querySelector('.action-menu');

                    // 🔥 OPEN MENU
                    dots.addEventListener('click', (e) => {
                        e.stopPropagation();
                        closeAllMenus();
                        menu.classList.toggle('show');
                    });

                    const deleteOption = menu.querySelector('.delete-item');

                    if (deleteOption) {
                        deleteOption.addEventListener('click', async (e) => {

                            e.stopPropagation();

                            const historyId = deleteOption.getAttribute('data-id');

                            if (!historyId) {
                                alert("Invalid history ID ❌");
                                return;
                            }

                            if (!confirm("Delete this history entry?")) return;

                            try {
                                const res = await fetch(`/National-Test-Series/history/delete/${historyId}`, {
                                    method: "DELETE",
                                    headers: {
                                        "Content-Type": "application/json"
                                    }
                                })

                                const data = await res.json(); // 🔥 IMPORTANT

                                // 🔐 LOGIN REQUIRED
                                if (res.status === 401) {
                                    alert("Please login first 🔐");
                                    window.location.href = "/login";
                                    return;
                                }

                                // ❌ ERROR
                                if (!res.ok || !data.success) {
                                    alert(data.msg || "Delete failed ❌");
                                    return;
                                }

                                // ✅ SUCCESS → REMOVE UI
                                const historyItem = actionsDiv.closest('.history-item');
                                if (historyItem) historyItem.remove();

                                // ✅ EMPTY STATE
                                if (document.querySelectorAll('.history-item').length === 0) {
                                    const container = document.querySelector('.history-container');
                                    const noHistoryMsg = document.createElement('p');
                                    noHistoryMsg.style.padding = "40px 0";
                                    noHistoryMsg.style.textAlign = "center";
                                    noHistoryMsg.style.color = "#606060";
                                    noHistoryMsg.innerHTML = '<i class="fas fa-folder-open"></i> No history found';
                                    container.appendChild(noHistoryMsg);
                                }

                            } catch (err) {
                                console.error("DELETE ERROR:", err);
                                alert("Server error ❌");
                            }

                            closeAllMenus();
                        });
                    }

                });

                // ================= CLICK OUTSIDE =================
                document.addEventListener('click', (e) => {
                    if (!e.target.closest('.history-actions')) {
                        closeAllMenus();
                    }
                });

            });
            function filterVideos() {
                const cards = Array.from(document.querySelectorAll(".history-item"));

                const input = document.getElementById("desktopSearchInput");
                if (!input) return; // 🔥 important fix

                const q = input.value.toLowerCase().trim();

                function getMatchScore(text, query) {
                    let score = 0;

                    if (text.includes(query)) score += 100;

                    const words = text.split(" ");
                    words.forEach(word => {
                        if (word.startsWith(query)) score += 50;
                        if (word.includes(query)) score += 20;
                    });

                    let matchCount = 0;
                    for (let char of query) {
                        if (text.includes(char)) matchCount++;
                    }

                    score += matchCount * 2;
                    return score;
                }

                let results = cards.map(card => {
                    const text = card.innerText.toLowerCase();
                    const score = q === "" ? 1 : getMatchScore(text, q);

                    return { card, score };
                });

                results = results.filter(item => item.score > 0);
                results.sort((a, b) => b.score - a.score);

                // 🔥 SHOW ALL IF EMPTY SEARCH
                if (q === "") {
                    cards.forEach(card => card.style.display = "flex");
                    return;
                }

                // 🔥 NO RESULT → SHOW ALL
                if (results.length === 0) {
                    cards.forEach(card => card.style.display = "flex");
                    return;
                }

                // 🔥 HIDE ALL
                cards.forEach(card => card.style.display = "none");

                // 🔥 SHOW MATCHED
                results.forEach(item => {
                    item.card.style.display = "flex";
                });
            }
            setTimeout(() => {
                const input = document.getElementById("desktopSearchInput");
                const btn = document.getElementById("desktopSearchBtn");

                if (input) {
                    input.addEventListener("input", filterVideos);
                    input.addEventListener("keypress", (e) => {
                        if (e.key === "Enter") filterVideos();
                    });
                }

                if (btn) {
                    btn.addEventListener("click", filterVideos);
                }
            }, 500);

            history = history.filter(item => item.test);
        </script>

</body>

</html>