<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>RIDTECH — Smart Search | Empty = All Videos | Sticky Chips</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/Allindiatestserice/testserice.css">
<link rel="stylesheet" href="/css/Allindiatestserice/shortmcq/shortmcqtest.css">
</head>

<body>

    <%- include("../common/allindiatestheader.ejs") %>

        <div class="short-container">
            <% let totalQuestions=questions.length; %>

                <% questions.forEach((q, idx)=> { %>
                    <div class="short">

                        <!-- Progress Bar -->
                        <div class="story-progress">
                            <% for(let i=0; i < totalQuestions; i++) { %>
                                <div
                                    class="progress-segment <%= i <= idx ? 'visited' : '' %> <%= i === idx ? 'active' : '' %>">
                                </div>
                                <% } %>
                        </div>

                        <!-- Card -->
                        <div class="creative-card">

                            <!-- Teacher Info -->
                            <div class="teacher-header">
                                <div class="teacher-avatar">👨‍🏫</div>
                                <div class="teacher-info">
                                    <div class="teacher-name">
                                        <%= q.teacher?.name || "Unknown Teacher" %>
                                    </div>
                                    <div class="teacher-badge">
                                        <span>🎓 Educator</span> • <span>⚡ MCQ</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Question -->
                            <div class="question-text">
                                <%= q.text %>
                            </div>

                            <!-- Options (FIXED 🔥) -->
                            <div class="options">
                                <% if(q.options && q.options.length> 0){ %>
                                    <% q.options.forEach((opt, i)=> { %>
                                        <button onclick="check(this, <%= opt.isCorrect %>)">
                                            <span class="opt-prefix">
                                                <%= String.fromCharCode(65+i) %>
                                            </span>
                                            <span>
                                                <%= opt.text %>
                                            </span>
                                        </button>
                                        <% }) %>
                                            <% } else { %>
                                                <p style="color:red;">No options found</p>
                                                <% } %>
                            </div>

                            <!-- Teacher Profile -->
                            <a href="/teacher/<%= q.teacher?._id %>" class="profile-link">
                                👤 View Teacher Profile →
                            </a>

                        </div>

                        <!-- Counter -->
                        <div class="question-counter">
                            <%= idx+1 %> / <%= totalQuestions %>
                        </div>

                    </div>
                    <% }); %>
        </div>

        <script>
            function check(btn, isCorrect) {
                if (isCorrect) {
                    btn.style.background = "green";
                } else {
                    btn.style.background = "red";
                }
            }
        </script>

</body>

</html>